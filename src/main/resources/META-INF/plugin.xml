<idea-plugin>
    <id>com.maxapp.branchknife</id>
    <name>Branch-Knife</name>
    <vendor>Maxapp</vendor>
    <description><![CDATA[
    在<strong>功能分支</strong>上，将相对 <code>master</code>/<code>main</code> 的<strong>已提交差异</strong>按目录规则拆成多个 <code>split/&lt;服务&gt;-&lt;时间戳&gt;</code> 分支，便于按服务提 PR。<br/><br/>
    <b>入口</b>：<b>Tools → Branch-Knife</b>，或 <b>Git</b> 菜单底部，或 <b>VCS Operations</b> 弹窗；亦可用 Find Action 搜索 <code>Slice</code>。
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>Git4Idea</depends>

    <actions>
        <!-- 同一 Action 多入口：Git 菜单、VCS 操作弹窗（如 Alt+` / 右键 VCS）、Tools 子菜单 -->
        <action id="com.maxapp.branchknife.SliceAction"
                class="com.maxapp.branchknife.SliceAction"
                text="Slice by Service..."
                description="将当前分支相对 master/main 的已提交差异按服务目录拆成多个 split 分支">
            <add-to-group group-id="Git.Menu" anchor="last"/>
            <add-to-group group-id="Vcs.Operations.Popup" anchor="last"/>
        </action>
        <group id="com.maxapp.branchknife.ToolsMenuGroup"
               text="Branch-Knife"
               description="Monorepo 按路径拆分分支"
               popup="true">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <reference ref="com.maxapp.branchknife.SliceAction"/>
        </group>
    </actions>
</idea-plugin>
